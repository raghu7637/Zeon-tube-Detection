import numpy as np
import pandas as pd
from scipy.optimize import linear_sum_assignment

def calculate_angle_error(pred_angle, gt_angle):
    """
    Calculates the shortest angular difference considering the 360-degree wrap-around.
    """
    diff = abs(pred_angle - gt_angle) % 360
    return min(diff, 360 - diff)

def evaluate_image_predictions(gt_df, pred_df, distance_threshold=20.0):
    """
    Evaluates predictions for a single image.
    
    Args:
        gt_df: DataFrame containing ground truth for a single image 
               (needs 'center_x', 'center_y', 'angle_deg')
        pred_df: DataFrame containing predictions for a single image
                 (needs 'center_x', 'center_y', 'angle_deg')
        distance_threshold: Max pixel distance to consider a match a True Positive.
    """
    if len(pred_df) == 0:
        return 0, 0, len(gt_df), [] # TP, FP, FN, angle_errors

    if len(gt_df) == 0:
        return 0, len(pred_df), 0, []
        
    gt_coords = gt_df[['center_x', 'center_y']].values
    pred_coords = pred_df[['center_x', 'center_y']].values
    
    # Cost matrix based on Euclidean distance
    cost_matrix = np.linalg.norm(gt_coords[:, np.newaxis] - pred_coords, axis=2)
    
    # Hungarian algorithm for optimal bipartite matching
    gt_indices, pred_indices = linear_sum_assignment(cost_matrix)
    
    tp = 0
    fp = len(pred_df)
    fn = len(gt_df)
    angle_errors = []
    
    for gt_idx, pred_idx in zip(gt_indices, pred_indices):
        dist = cost_matrix[gt_idx, pred_idx]
        
        if dist <= distance_threshold:
            tp += 1
            fp -= 1
            fn -= 1
            
            # Calculate angle error for True Positives
            gt_angle = gt_df.iloc[gt_idx]['angle_deg']
            pred_angle = pred_df.iloc[pred_idx]['angle_deg']
            error = calculate_angle_error(pred_angle, gt_angle)
            angle_errors.append(error)
            
    return tp, fp, fn, angle_errors

def evaluate_dataset(ground_truth_csv, predictions_df, distance_threshold=20.0):
    """
    Runs the full evaluation pipeline across the dataset.
    """
    gt_data = pd.read_csv(ground_truth_csv)
    
    total_tp = 0
    total_fp = 0
    total_fn = 0
    all_angle_errors = []
    
    unique_images = gt_data['image'].unique()
    
    for img_name in unique_images:
        gt_img = gt_data[gt_data['image'] == img_name]
        pred_img = predictions_df[predictions_df['image'] == img_name]
        
        tp, fp, fn, errors = evaluate_image_predictions(gt_img, pred_img, distance_threshold)
        
        total_tp += tp
        total_fp += fp
        total_fn += fn
        all_angle_errors.extend(errors)
        
    precision = total_tp / (total_tp + total_fp) if (total_tp + total_fp) > 0 else 0
    recall = total_tp / (total_tp + total_fn) if (total_tp + total_fn) > 0 else 0
    f1 = 2 * (precision * recall) / (precision + recall) if (precision + recall) > 0 else 0
    mean_angle_error = np.mean(all_angle_errors) if all_angle_errors else 0
    
    print("--- Evaluation Results ---")
    print(f"Precision:  {precision:.4f}")
    print(f"Recall:     {recall:.4f}")
    print(f"F1 Score:   {f1:.4f}")
    print(f"MAE Angle:  {mean_angle_error:.2f}°")
    
    return precision, recall, f1, mean_angle_error
